# Optional. Defaults to examples/portfolio.
JOB_APPLICATION_DRAFT_PORTFOLIO_ROOT=examples/portfolio

# Optional. Generated context cache. Do not commit real generated context.
JOB_APPLICATION_DRAFT_CONTEXT_DIR=data/context

# Optional. Runtime data location for SQLite drafts and Codex run workspaces.
JOB_APPLICATION_DRAFT_RUNTIME_DIR=.runtime
JOB_APPLICATION_DRAFT_DB_PATH=.runtime/drafts.db
JOB_APPLICATION_DRAFT_CODEX_RUNS_DIR=.runtime/codex-runs

# Optional. Defaults to `codex` on PATH.
JOB_APPLICATION_DRAFT_CODEX_BINARY=codex
JOB_APPLICATION_DRAFT_CODEX_MODEL=gpt-5.5
JOB_APPLICATION_DRAFT_CODEX_REASONING_EFFORT=low
JOB_APPLICATION_DRAFT_CODEX_TIMEOUT_SECONDS=180
JOB_APPLICATION_DRAFT_MAX_WORKERS=5

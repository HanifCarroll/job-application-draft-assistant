#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

uv --no-config run mypy src tests
uv --no-config run pytest

find extension -name '*.js' -print0 | sort -z | xargs -0 -n1 node --check

python3 -m json.tool extension/manifest.json >/dev/null
python3 -m json.tool schemas/draft_response.schema.json >/dev/null

git diff --check
